# EchoChamber web — copy to .env.local and adjust as needed.

# Orchestrator REST + WebSocket base URLs.
NEXT_PUBLIC_SERVER_URL=http://localhost:8787
NEXT_PUBLIC_WS_URL=ws://localhost:8787

# Drive the room with the in-browser mock orchestrator. The server stub only
# implements GET /api/experts today; with mock mode on, suggest-panel, room
# creation, the per-room WebSocket debate, audio queue and DeepWiki indexing all
# run client-side so every screen is demoable end-to-end without API keys.
# Set to "false" once the real orchestrator ships the full @echochamber/shared
# contract (per-room WS + REST routes).
NEXT_PUBLIC_USE_MOCK=true
