# ── EchoChamber environment ───────────────────────────────────────────────
# Copy to .env and fill in. In Devin child sessions these are provided as
# org-scoped secrets and injected automatically — no need to paste them.

# Google Gemini — core LLM brain (agent generation, topic classification, STT)
GEMINI_API_KEY=

# SLNG — per-expert voice profiles / TTS (Unified API; model in the URL path).
# Body is { voice, text }; response is audio/wav. See https://docs.slng.ai
SLNG_API_KEY=
SLNG_BASE_URL=https://api.slng.ai/v1/bridges/unmute/tts
SLNG_MODEL=slng/deepgram/aura:2-en

# Tavily — search + extract for grounding prep and DeepWiki runtime indexing
TAVILY_API_KEY=

# Superlinked SIE — embeddings / rerank / structured output / guardrails
# OpenAI-compatible /v1 endpoint.
SUPERLINKED_API_KEY=
SUPERLINKED_BASE_URL=

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8787
# Public URL of the orchestrator, used by the web app.
NEXT_PUBLIC_SERVER_URL=http://localhost:8787
NEXT_PUBLIC_WS_URL=ws://localhost:8787

# Feature flags / toggles
# Set to "mock" to run the whole stack without any external API (demo/dev).
ECHO_ADAPTER_MODE=mock
